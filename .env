# =====================================================================
#  Polymarket Copy-Trading Bot – Environment Variables
# =====================================================================

# ── Alchemy (Polygon) – Solo WSS, Zero-RPC ──────────────────────────
POLYGON_WSS_URL=wss://polygon-mainnet.g.alchemy.com/v2/ZC4Py3J9PWuc_XEaamQ2_
# POLYGON_RPC_URL ya NO se usa (zero-RPC architecture)

# ── Whale Wallets (Static Topic Filter – Zero-RPC) ──────────────────
# Formato: Label:EOA[:proxy1,proxy2]
# Separar múltiples whales con ;
#
# Solo EOA (si aparece directamente en topic maker/taker):
#   WHALE_WALLETS=DrPufferfish:0xdb27bf2ac5d428a9c63dbc914611036855a6c56e
#
# Con proxy wallets (si el whale opera via Gnosis Safe):
#   WHALE_WALLETS=DrPufferfish:0xdb27bf...:0xproxy1,0xproxy2
#
# Múltiples whales:
#   WHALE_WALLETS=DrPufferfish:0xdb27bf...:0xproxyA;LucasMeow:0xabc...
#
# NOTA: busca las proxy wallets del whale en Polygonscan o en el
#       historial de OrderFilled del CTFExchange.
WHALE_WALLETS="DrPufferfish:0xdb27bf2ac5d428a9c63dbc914611036855a6c56e;LucasMeow:0x7f3c8979d0afa00007bae4747d5347122af05613;Tsybka:0xd5ccdf772f795547e299de57f47966e24de8dea4"

# ── Copy-Trading Parameters ─────────────────────────────────────────
COPY_MAX_SLIPPAGE_PCT=0.05
COPY_POSITION_SIZE_PCT=0.10
COPY_MIN_WHALE_SIZE_USD=100.0
COPY_MAX_PRICE=0.985
COPY_MIN_PRICE=0.05
COPY_MODE=paper

# ── General ──────────────────────────────────────────────────────────
INITIAL_CAPITAL=50.0
LOG_LEVEL=INFO
