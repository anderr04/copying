# =====================================================================
#  Polymarket Copy-Trading Bot – Environment Variables
# =====================================================================

# ── Alchemy (Polygon) ───────────────────────────────────────────────
# Obtener en: https://dashboard.alchemy.com/
POLYGON_WSS_URL=wss://polygon-mainnet.g.alchemy.com/v2/TU_API_KEY_AQUI
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/TU_API_KEY_AQUI

# ── Whale Wallets ────────────────────────────────────────────────────
# Formato: Label1:0xDireccion1,Label2:0xDireccion2,...
# Obtener las direcciones Polygon de cada whale desde Polygonscan
# o desde su perfil público de Polymarket.
WHALE_WALLETS=DrPufferfish:0x_DIRECCION_AQUI,LucasMeow:0x_DIRECCION_AQUI,Tsybka:0x_DIRECCION_AQUI

# ── Copy-Trading Parameters ─────────────────────────────────────────
COPY_MAX_SLIPPAGE_PCT=0.01
COPY_POSITION_SIZE_PCT=0.10
COPY_MIN_WHALE_SIZE_USD=100.0
COPY_MAX_PRICE=0.95
COPY_MIN_PRICE=0.05
COPY_MODE=paper

# ── General ──────────────────────────────────────────────────────────
INITIAL_CAPITAL=50.0
LOG_LEVEL=INFO
